NODE_ENV=production
PORT=5001

# PostgreSQL database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=landlord_db
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# Alternative single-url connection for Render/managed Postgres
# DATABASE_URL=postgres://user:password@host:5432/database

# Security
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=landlordpro_token
AUTH_COOKIE_SAMESITE=none

# Allowed frontend origins
FRONTEND_URLS=https://app.yourdomain.com,https://www.app.yourdomain.com,https://landlordpro.co.tz,https://www.landlordpro.co.tz
PLATFORM_ADMIN_EMAILS=admin@yourdomain.com
EMAIL_DELIVERY_REQUIRED=true

# SMTP email delivery
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=LandlordPro
PASSWORD_RESET_HOURS=1

# Beem SMS (https://engage.beem.africa)
BEEM_API_KEY=your_beem_api_key
BEEM_SECRET_KEY=your_beem_secret_key
BEEM_SENDER_ID=LandlordPro

# Reverse proxy / load balancer
TRUST_PROXY=true

# App
APP_NAME=LandlordPro
CURRENCY=TZS
REMINDER_DAYS=7

# Default admin seed (used by `npm run seed`)
DEFAULT_ADMIN_EMAIL=admin@landlordpro.com
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_ADMIN_PHONE=
DEFAULT_ORG_NAME=LandlordPro
DEFAULT_ORG_SLUG=landlordpro-default
SEED_CONTINUE_ON_ERROR=true
