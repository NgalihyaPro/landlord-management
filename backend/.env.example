NODE_ENV=production
PORT=5001

# PostgreSQL database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=landlord_db
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Security
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=landlordpro_token
AUTH_COOKIE_SAMESITE=none

# Allowed frontend origins
FRONTEND_URLS=https://app.yourdomain.com,https://www.app.yourdomain.com
PLATFORM_ADMIN_EMAILS=admin@yourdomain.com
EMAIL_DELIVERY_REQUIRED=true

# SMTP email delivery
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=LandlordPro
PASSWORD_RESET_HOURS=1

# Reverse proxy / load balancer
TRUST_PROXY=true

# App
APP_NAME=LandlordPro
CURRENCY=TZS
REMINDER_DAYS=7
