NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Public URLs
API_PUBLIC_URL=https://api.landlordpro.co.tz/api
FRONTEND_URL=https://landlordpro.co.tz
FRONTEND_URLS=https://landlordpro.co.tz,https://www.landlordpro.co.tz,http://localhost:5173,http://localhost:3000

# PostgreSQL database. Prefer DATABASE_URL in Coolify.
DATABASE_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10

# Optional local PostgreSQL settings when DATABASE_URL is not set.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=landlord_db

# Security
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
SESSION_SECRET=replace_with_a_long_random_session_secret
AUTH_COOKIE_NAME=landlordpro_token
AUTH_COOKIE_SAMESITE=none
CSRF_COOKIE_NAME=landlordpro_csrf

# Platform access
PLATFORM_ADMIN_EMAILS=admin@landlordpro.co.tz
EMAIL_DELIVERY_REQUIRED=true

# Email delivery
ZEPTO_API_URL=https://api.zeptomail.com/v1.1/email
ZEPTO_API_TOKEN=your_zeptomail_send_mail_token
EMAIL_REQUEST_TIMEOUT_MS=15000
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=emailapikey
SMTP_PASSWORD=your_zeptomail_password
SMTP_FROM_EMAIL=invites@landlordpro.co.tz
SMTP_FROM_NAME=LandlordPro
PASSWORD_RESET_HOURS=1

# Beem SMS
BEEM_API_KEY=your_beem_api_key
BEEM_SECRET_KEY=your_beem_secret_key
BEEM_SENDER_ID=LandlordPro

# Reverse proxy / load balancer
TRUST_PROXY=true

# App
APP_NAME=LandlordPro
CURRENCY=TZS
REMINDER_DAYS=7
DISABLE_CRON=false

# Default admin seed. Run manually with `npm run deploy:seed`.
DEFAULT_ADMIN_EMAIL=admin@landlordpro.co.tz
DEFAULT_ADMIN_PASSWORD=change_this_before_seeding
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_ADMIN_PHONE=
DEFAULT_ORG_NAME=LandlordPro
DEFAULT_ORG_SLUG=landlordpro-default
SEED_CONTINUE_ON_ERROR=true
